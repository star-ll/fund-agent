# ── LLM ──────────────────────────────────────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# ── AKShare 数据服务 ──────────────────────────────────
# Docker 部署时被 docker-compose environment 覆盖为 http://server:8080
AKSHARE_BASE_URL=http://localhost:8080

# ── 阿里云 OCR ────────────────────────────────────────
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret

# ── Discord ───────────────────────────────────────────
DISCORD_PUBLIC_KEY=your-app-public-key
DISCORD_APP_ID=your-application-id
DISCORD_BOT_TOKEN=your-bot-token

# ── MySQL ─────────────────────────────────────────────
# Docker 部署时 MYSQL_HOST 被 docker-compose environment 覆盖为 mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=ai_fund

# ── Redis ─────────────────────────────────────────────
# Docker 部署时 REDIS_HOST 被 docker-compose environment 覆盖为 redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ── 代理（可选，用于访问 Discord API）────────────────────
# HTTPS_PROXY=http://127.0.0.1:7890
