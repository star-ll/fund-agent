{
  "name": "ai-fund",
  "version": "1.0.0",
  "description": "AI基金分析助理",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node packages/cli/index.ts",
    "webhook": "ts-node packages/discord/webhook-entry.ts",
    "build": "tsc && cp src/prompts/*.md dist/src/prompts/ && mkdir -p dist/packages/discord/prompts dist/packages/cli/prompts && cp packages/discord/prompts/*.md dist/packages/discord/prompts/ && cp packages/cli/prompts/*.md dist/packages/cli/prompts/",
    "start": "node dist/packages/discord/webhook-entry.js",
    "server": "cd server && uv run uvicorn main:app --host 0.0.0.0 --port 8080",
    "server:dev": "cd server && uv run uvicorn main:app --host 0.0.0.0 --port 8080 --reload",
    "discord:register": "ts-node packages/discord/register-commands.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pnpm": {
    "overrides": {
      "es-object-atoms": "1.1.1",
      "ws": "8.20.1"
    }
  },
  "dependencies": {
    "@types/form-data": "^2.5.2",
    "axios": "^1.7.9",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "https-proxy-agent": "5.0.1",
    "ioredis": "^5.10.1",
    "mysql2": "^3.22.3",
    "openai": "^4.77.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.7",
    "@types/xml2js": "^0.4.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
